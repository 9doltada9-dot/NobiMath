# ──────────────────────────────────────────────────────────────────────────────
# Nobi Skill — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it's in .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# Supabase Project URL — found in: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key — found in: Supabase Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Gemini API Key — stored as Supabase Secret (NOT here), set it with:
#   supabase secrets set GEMINI_API_KEY=your-key --project-ref your-ref
# Get key from: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────────────────────
